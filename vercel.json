{
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/api/auth-register",
      "dest": "/api/auth-register"
    },
    {
      "src": "/api/auth-login",
      "dest": "/api/auth-login"
    },
    {
      "src": "/api/posts",
      "dest": "/api/posts"
    },
    {
      "src": "/api/post",
      "dest": "/api/post"
    },
    {
      "src": "/api/post-comments",
      "dest": "/api/post-comments"
    },
    {
      "src": "/api/comment",
      "dest": "/api/comment"
    },
    {
      "src": "/api/search",
      "dest": "/api/search"
    },
    {
      "src": "/api/debug",
      "dest": "/api/debug"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*\\.(svg|ico|png|jpg|jpeg|gif|webp))$",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}